{
  "name": "smart-learning-server",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "test": "jest --verbose --coverage --passWithNoTests",
    "dev": "nodemon server.js",
  "start": "node server.js",
  "seed:min": "node scripts/seedMin.js"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  },
  "keywords": [
    "education",
    "learning",
    "ai",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "description": "Smart Learning Platform Backend API",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "firebase-admin": "^13.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.5",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.1.8",
    "supertest": "^7.0.0"
  }
}
